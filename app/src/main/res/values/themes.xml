<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.QuickStack" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <style name="Theme.QuickStack.Dialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">95%</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="Theme.QuickStack.TransparentCapture" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowDisablePreview">true</item>
    </style>
</resources>
